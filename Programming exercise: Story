# This is a program that keeps asking the user for words and ends when the user types in end and pritns ou the words entered

#helper variable 

words = ''
comparison = ''

# while loop

while True:
    word = input('Please type in a word: ')
    if word == 'end':
        break
    else:
        if word == comparison:
            break
        else:
            words += word + ' '
    comparison = word    
   

print(words)
