# this program determines the next leap year after a year entered by the user

year = int(input('Please type in a year: '))

leap_year = year + 1

# if is divisible by 4 but not 100 it is a leap year. If it is divisible by 100 it must also be divisible by 400 to be
# leap year

while True:
    if leap_year % 4 == 0:
        if leap_year % 100 != 0:
            break
        else:
            if leap_year % 400 == 0:
                break
    leap_year +=1






print(f'The next leap year after {year} is {leap_year}')
